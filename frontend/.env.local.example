# Copy to .env.local and fill in. NEXT_PUBLIC_* values are public on-chain
# addresses and are safe to share. B20_RPC_URL is a server-only secret and must
# NOT be committed.

# Base Sepolia (testnet) = 84532, Base mainnet = 8453
NEXT_PUBLIC_CHAIN_ID=84532

# Deployed B20factory stack (Base Sepolia testnet defaults shown)
NEXT_PUBLIC_LAUNCHPAD=0x0e56e3e9C0C6209F10AdE0A3DED1daf252B7b309
NEXT_PUBLIC_TOKEN_FACTORY=0x35deBD09cA16f264DC37506C4A58a5b85AD9fD16
NEXT_PUBLIC_FEE_HOOK=0x0783bB68D3a3e4C2f061Da49669EC01f28cEE0CC
NEXT_PUBLIC_SWAP_ROUTER=0x7960d31705394094a4667ee3dB203455Ce7a1e7E
NEXT_PUBLIC_POOL_MANAGER=0x05E73354cFDd6745C338b50BcFDfA3Aa6fA03408

# Optional off-chain metadata helper (leave blank to use the built-in store)
NEXT_PUBLIC_PROFILE_API=

# Server-only: keyed RPC used by the /api/rpc proxy. Put your own provider key
# here in .env.local (never commit the real value).
B20_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
