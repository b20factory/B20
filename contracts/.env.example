# Copy to .env and fill in. Never commit the real .env.

# Deployer key for Base Sepolia (testnet)
PRIVATE_KEY=

# Basescan API key (contract verification)
BASESCAN_API_KEY=

# Mainnet deployer key (keep separate from the testnet key)
MAINNET_PRIVATE_KEY=

# Oracle / treasury address used by deploy scripts
MAINNET_ORACLE_ADDRESS=

# Keyed RPC endpoints (your own provider keys)
MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
